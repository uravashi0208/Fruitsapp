/**
 * src/api/client.ts
 * Core fetch wrapper — auto JWT refresh, consistent errors, typed responses.
 */

export const API_BASE = process.env.REACT_APP_API_URL || 'http://localhost:4000';

// ── Token helpers ─────────────────────────────────────────────
export const getAccessToken  = (): string | null => sessionStorage.getItem('vf_access');
export const getRefreshToken = (): string | null => localStorage.getItem('vf_refresh');

export const setTokens = (access: string, refresh: string): void => {
  sessionStorage.setItem('vf_access',  access);
  localStorage.setItem('vf_refresh', refresh);
};

export const clearTokens = (): void => {
  sessionStorage.removeItem('vf_access');
  localStorage.removeItem('vf_refresh');
};

// ── Typed error ───────────────────────────────────────────────
export class ApiError extends Error {
  status:  number;
  details: unknown;
  constructor(message: string, status: number, details?: unknown) {
    super(message);
    this.name    = 'ApiError';
    this.status  = status;
    this.details = details;
  }
}

// ── Refresh queue (prevents multiple refresh calls) ───────────
let _refreshing = false;
let _queue: Array<(t: string) => void> = [];
const flushQueue = (token: string) => { _queue.forEach((fn) => fn(token)); _queue = []; };

// ── Core request ──────────────────────────────────────────────
type Method = 'GET' | 'POST' | 'PUT' | 'PATCH' | 'DELETE';

interface Opts {
  body?:   unknown;
  headers?: Record<string, string>;
  noAuth?: boolean;
  _retry?: boolean;
}

export async function request<T = unknown>(
  method: Method,
  path: string,
  opts: Opts = {}
): Promise<T> {
  const { body, headers = {}, noAuth = false, _retry = false } = opts;

  const token = getAccessToken();
  const reqHeaders: Record<string, string> = {
    'Content-Type': 'application/json',
    ...headers,
  };
  if (!noAuth && token) reqHeaders['Authorization'] = `Bearer ${token}`;

  const res = await fetch(`${API_BASE}${path}`, {
    method,
    headers: reqHeaders,
    ...(body !== undefined ? { body: JSON.stringify(body) } : {}),
  });

  // Auto-refresh on 401
  if (res.status === 401 && !_retry && !noAuth) {
    const refresh = getRefreshToken();
    if (!refresh) {
      clearTokens();
      window.dispatchEvent(new Event('vf:logout'));
      throw new ApiError('Session expired. Please log in again.', 401);
    }

    if (_refreshing) {
      return new Promise((resolve, reject) => {
        _queue.push(async (newToken) => {
          try {
            resolve(await request<T>(method, path, {
              ...opts,
              headers: { ...headers, Authorization: `Bearer ${newToken}` },
              _retry: true,
            }));
          } catch (e) { reject(e); }
        });
      });
    }

    _refreshing = true;
    try {
      const rr   = await fetch(`${API_BASE}/api/admin/auth/refresh`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ refreshToken: refresh }),
      });
      const rd = await rr.json();
      if (!rr.ok) throw new Error('refresh_failed');
      const newAccess = rd.data.accessToken;
      sessionStorage.setItem('vf_access', newAccess);
      flushQueue(newAccess);
      return request<T>(method, path, {
        ...opts,
        headers: { ...headers, Authorization: `Bearer ${newAccess}` },
        _retry: true,
      });
    } catch {
      clearTokens();
      window.dispatchEvent(new Event('vf:logout'));
      throw new ApiError('Session expired. Please log in again.', 401);
    } finally {
      _refreshing = false;
    }
  }

  const json = await res.json().catch(() => ({ error: 'Invalid server response' }));
  if (!res.ok) throw new ApiError(json.error || `HTTP ${res.status}`, res.status, json);
  return json as T;
}

const api = {
  get:    <T>(path: string, o?: Opts) => request<T>('GET',    path, o),
  post:   <T>(path: string, body?: unknown, o?: Opts) => request<T>('POST',   path, { ...o, body }),
  put:    <T>(path: string, body?: unknown, o?: Opts) => request<T>('PUT',    path, { ...o, body }),
  patch:  <T>(path: string, body?: unknown, o?: Opts) => request<T>('PATCH',  path, { ...o, body }),
  delete: <T>(path: string, o?: Opts) => request<T>('DELETE', path, o),
};

export default api;
